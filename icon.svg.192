<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">

  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="192" y2="192">
      <stop offset="0%" stop-color="#10b981"></stop>
      <stop offset="50%" stop-color="#0f766e"></stop>
      <stop offset="100%" stop-color="#1d4ed8"></stop>
    </linearGradient>

    <linearGradient id="card" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#ffffff"></stop>
      <stop offset="100%" stop-color="#dff7f4"></stop>
    </linearGradient>

    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="#063b3f" flood-opacity="0.30"></feDropShadow>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="192" height="192" rx="48" fill="url(#bg)"></rect>

  <!-- Decorative -->
  <circle cx="42" cy="42" r="12" fill="#fff" opacity="0.15"></circle>
  <circle cx="150" cy="150" r="18" fill="#fff" opacity="0.10"></circle>

  <!-- Star -->
  <path d="M145 34
           L149 42
           L158 45
           L149 48
           L145 57
           L141 48
           L132 45
           L141 42 Z" fill="#facc15"></path>

  <!-- Main Card (Safe Area) -->
  <rect x="48" y="34" width="96" height="108" rx="18" fill="url(#card)" filter="url(#shadow)"></rect>

  <!-- List -->
  <rect x="64" y="52" width="60" height="8" rx="4" fill="#0f766e"></rect>
  <rect x="64" y="70" width="48" height="7" rx="3.5" fill="#14b8a6"></rect>
  <rect x="64" y="87" width="40" height="7" rx="3.5" fill="#2563eb"></rect>

  <!-- Check -->
  <circle cx="72" cy="114" r="14" fill="#0f766e"></circle>
  <path d="M66 114
           L71 119
           L79 108" fill="none" stroke="#ffffff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>

  <!-- Text -->
  <text x="96" y="166" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="14" font-weight="700" fill="#ffffff">
    TO-DO
  </text>

</svg>
